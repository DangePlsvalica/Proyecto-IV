generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoUsuario {
  Activo
  Inactivo
  Bloqueado
}

enum TipoEvento {
  Formativo
  Agricola
  ConsultaPopular
}

model Comuna {
  codigo_situr      String              @id @db.VarChar(20)
  nombre            String              @db.VarChar(100)
  municipio         String              @db.VarChar(100)
  parroquia         String              @db.VarChar(100)
  lindero_norte     String?             @db.Text
  lindero_sur       String?             @db.Text
  lindero_este      String?             @db.Text
  lindero_oeste     String?             @db.Text
  consejos_comunales ConsejoComunal[]
  proyectos         Proyecto[]
  eventos           Evento[]
  actividades_economicas ActividadEconomica[]
}

model ConsejoComunal {
  codigo_situr      String             @id @db.VarChar(20)
  nombre            String             @db.VarChar(100)
  fecha_eleccion    DateTime
  poblacion_total   Int
  cant_hombres      Int
  cant_mujeres      Int
  telefono          String             @db.VarChar(15)
  comuna            Comuna             @relation(fields: [codigo_situr_comuna], references: [codigo_situr])
  codigo_situr_comuna String           @db.VarChar(20)
  voceros           Vocero[]
  inventario_carros InventarioCarros[]
  usuarios          Usuario[]
  proyectos_votados ProyectoVotacion[]
}

model Usuario {
  correo            String        @id @db.VarChar(100)
  contraseña        String        @db.Char(60)
  fecha_registro    DateTime      @default(now())
  ultimo_acceso     DateTime?
  estado            EstadoUsuario @default(Activo)
  consejo_comunal   ConsejoComunal? @relation(fields: [codigo_situr_consejo], references: [codigo_situr])
  codigo_situr_consejo String?    @db.VarChar(20)
}

model Proyecto {
  id_proyecto       Int           @id @default(autoincrement())
  nombre            String        @db.VarChar(200)
  descripcion       String?       @db.Text
  estatus           String        @db.VarChar(50)
  fecha_inicio      DateTime
  fecha_fin         DateTime?
  comentarios       String?       @db.Text
  votos             Int           @default(0)
  comuna            Comuna        @relation(fields: [codigo_situr_comuna], references: [codigo_situr])
  codigo_situr_comuna String      @db.VarChar(20)
  eventos           Evento[]
  observaciones     Observacion[]
  votantes          ProyectoVotacion[]
}

model InventarioCarros {
  placa             String        @id @db.VarChar(15)
  marca             String        @db.VarChar(50)
  modelo            String        @db.VarChar(50)
  color             String?       @db.VarChar(30)
  anio              Int
  serial_carroceria String        @unique @db.VarChar(50)
  estatus           String        @db.VarChar(50)
  consejo_comunal   ConsejoComunal @relation(fields: [codigo_situr_consejo], references: [codigo_situr])
  codigo_situr_consejo String     @db.VarChar(20)
}

model Evento {
  id_evento         Int           @id @default(autoincrement())
  tipo              TipoEvento
  nombre            String        @db.VarChar(200)
  descripcion       String?       @db.Text
  fecha_inicio      DateTime
  fecha_fin         DateTime?
  estado            String        @db.VarChar(50)
  comentarios       String?       @db.Text
  comuna            Comuna        @relation(fields: [codigo_situr_comuna], references: [codigo_situr])
  codigo_situr_comuna String      @db.VarChar(20)
  proyecto          Proyecto?     @relation(fields: [id_proyecto], references: [id_proyecto])
  id_proyecto       Int?
}

model Vocero {
  cedula            String        @id @db.VarChar(15)
  nombre_completo   String        @db.VarChar(150)
  cargo             String        @db.VarChar(100)
  consejo_comunal   ConsejoComunal @relation(fields: [codigo_situr_consejo], references: [codigo_situr])
  codigo_situr_consejo String     @db.VarChar(20)
}

model Observacion {
  id_observacion    Int           @id @default(autoincrement())
  fecha_entrega     DateTime      @default(now())
  asignacion        String        @db.VarChar(100)
  sistema_cargo     String        @db.VarChar(100)
  proyecto          Proyecto      @relation(fields: [id_proyecto], references: [id_proyecto])
  id_proyecto       Int
}

model ActividadEconomica {
  codigo            String        @id @db.VarChar(20)
  nombre_ospc       String        @db.VarChar(200)
  tipo_actividad    String        @db.VarChar(100)
  comuna            Comuna        @relation(fields: [codigo_situr_comuna], references: [codigo_situr])
  codigo_situr_comuna String      @db.VarChar(20)
}

model ProyectoVotacion {
  proyecto          Proyecto      @relation(fields: [id_proyecto], references: [id_proyecto])
  consejo_comunal   ConsejoComunal @relation(fields: [codigo_situr_consejo], references: [codigo_situr])
  id_proyecto       Int
  codigo_situr_consejo String     @db.VarChar(20)

  @@id([id_proyecto, codigo_situr_consejo])
}